#!/usr/bin/env bash
# qoneqt-mcp git hook: post-merge (runs after `git pull` / `git merge`)
# Records a merge event with the current local git user as the actor.
# The MCP file watcher will catch the file changes itself; this hook just
# logs the merge metadata.

set -u
WS="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
EVENTS_DIR="$WS/.qoneqt-mcp"
EVENTS_FILE="$EVENTS_DIR/git-events.jsonl"
mkdir -p "$EVENTS_DIR" 2>/dev/null

USER_NAME="$(git config user.name 2>/dev/null)"
[ -z "$USER_NAME" ] && USER_NAME="$USER"
USER_EMAIL="$(git config user.email 2>/dev/null)"
HEAD_SHA="$(git rev-parse HEAD 2>/dev/null)"
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
TS="$(date +%s)"

esc() { printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'; }
NAME_J=$(esc "$USER_NAME")
EMAIL_J=$(esc "$USER_EMAIL")
DETAIL_J=$(esc "branch=$BRANCH")

printf '{"ts":%s,"user":%s,"email":%s,"source":"merge","ref":"%s","action":"merged","detail":%s}\n' \
  "$TS" "$NAME_J" "$EMAIL_J" "$HEAD_SHA" "$DETAIL_J" >> "$EVENTS_FILE"

exit 0
